# Copy to .env.local for overrides (optional).
# Vite exposes only variables prefixed with VITE_.

# Local dev: omit VITE_API_URL to use Vite proxy (recommended — avoids CORS).
# VITE_API_URL=
# Direct API (requires backend CORS for http://localhost:5173):
# VITE_API_URL=http://127.0.0.1:8000

# Production (GitHub Pages build uses .env.production automatically):
# VITE_API_URL=https://mdqm-backend.onrender.com
