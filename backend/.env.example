# Copy to .env for local development. On Render, set these in the service dashboard.

# --- PostgreSQL (local) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=mdms

# Render injects DATABASE_URL when a Postgres instance is linked (overrides POSTGRES_*).
# DATABASE_URL=postgresql://user:pass@host:5432/mdms
# DATABASE_SSLMODE=require

# --- App / deployment ---
ENV=development
# CORS_ORIGINS=http://localhost:5173,https://analytix-hub-technologies-pvt-ltd.github.io
MDQM_FRONTEND_URL=http://localhost:5173

# --- Auth / RBAC ---
JWT_SECRET=change-me-in-production
MDQM_BOOTSTRAP_SECRET=your-bootstrap-secret
ACCESS_REQUEST_NOTIFY_EMAIL=you@example.com

# --- Microsoft Graph (email invites / notifications) ---
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER_EMAIL=

# --- SharePoint export (optional) ---
SP_TENANT_ID=
SP_CLIENT_ID=
SP_CLIENT_SECRET=
SP_DRIVE_ID=
SP_FOLDER_PATH=MDQM-Exports
